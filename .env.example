GRPC_ENDPOINT=https://your-yellowstone-endpoint:443
GRPC_TOKEN=your-x-token-here
WALLET_KEYPAIR_PATH=/Users/you/.config/solana/id.json
RPC_URL=https://api.mainnet-beta.solana.com
POOLS_CONFIG_PATH=pools.json

# Arbitrage parameters
MIN_PROFIT_LAMPORTS=10000
INPUT_SOL_LAMPORTS=100000000
SLIPPAGE_BPS=50

# Jito tip: 0.0 = 0%, 0.5 = 50% of gross profit goes to tip
TIP_RATIO=0.51
MAX_TIP_LAMPORTS=1000000

# Set to true to log bundles without submitting
DRY_RUN=false

# tracing filter: info, debug, warn
RUST_LOG=solana_mev=info
